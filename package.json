{
  "name": "Surfingkeys",
  "version": "1.18.0",
  "description": "Map your keys for web surfing, expand your browser with javascript and keyboard.",
  "main": "background.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "clean": "rm -rf dist/*",
    "build:doc": "documentation build src/content_scripts/common/api.js src/content_scripts/common/normal.js src/content_scripts/common/clipboard.js src/content_scripts/common/hints.js src/content_scripts/common/visual.js src/content_scripts/front.js src/user_scripts/index.js -f md -o docs/api.md",
    "build:dev": "webpack --mode=development --config ./config/webpack.config.js",
    "build:prod": "webpack --mode=production --config ./config/webpack.config.js",
    "build:testdata": "webpack --mode=production --config ./config/webpack.test.config.js",
    "build:watch": "webpack --mode=development --watch --config ./config/webpack.config.js",
    "build": "npm-run-all clean test build:doc build:prod",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brookhong/Surfingkeys.git"
  },
  "author": "brook hong",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/brookhong/Surfingkeys/issues"
  },
  "homepage": "https://github.com/brookhong/Surfingkeys#readme",
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@types/events": "^3.0.3",
    "@types/jest-image-snapshot": "^4.3.2",
    "@types/lodash": "^4.17.24",
    "@types/offscreencanvas": "^2019.7.3",
    "babel-plugin-module-resolver": "^4.1.0",
    "copy-webpack-plugin": "^9.1.0",
    "documentation": "^14.0.3",
    "file-loader": "^6.2.0",
    "filemanager-webpack-plugin": "^8.0.0",
    "jest": "^27.5.1",
    "jest-image-snapshot": "^4.5.1",
    "npm-run-all": "^4.1.5",
    "puppeteer": "^24.40.0",
    "strict-event-emitter-types": "^2.0.0",
    "string-replace-loader": "^3.3.0",
    "style-loader": "^3.3.4",
